// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  ownedProjects Project[]
  memberships   ProjectMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id             String          @id @default(cuid())
  name           String
  description    String?
  sprintDuration Int             @default(14)
  startDate      DateTime        @default(now())
  color          String          @default("#6366f1")
  ownerId        String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  owner          User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  activities     Activity[]
  members        ProjectMember[]
  featureGroups  FeatureGroup[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("VIEWER") // OWNER, EDITOR, VIEWER
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Activity {
  id              String               @id @default(cuid())
  name            String
  description     String?
  color           String               @default("#6366f1")
  durationSprints Int                  @default(1)
  startDate       DateTime?
  rowIndex        Int?
  isDelivered     Boolean              @default(false)
  deliveryDate    DateTime?
  deliveryLabel   String?
  projectId       String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  // Planning fields
  quarter         String?
  area            String?
  planStatus      String               @default("Backlog")
  team            String?
  sizeLabel       String?
  origin          String?
  clients         String[]
  jiraRef         String?
  planningNote    String?
  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tags            ActivityTag[]
  dependsOn       ActivityDependency[]  @relation("dependent")
  blockedBy       ActivityDependency[]  @relation("blocker")
  featureGroups   FeatureGroupActivity[]
}

model ActivityTag {
  id         String   @id @default(cuid())
  name       String
  color      String   @default("#94a3b8")
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model ActivityDependency {
  id     String   @id @default(cuid())
  fromId String
  toId   String
  from   Activity @relation("blocker", fields: [fromId], references: [id], onDelete: Cascade)
  to     Activity @relation("dependent", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
}

model FeatureGroup {
  id          String                @id @default(cuid())
  projectId   String
  title       String                @default("Novo Grupo")
  description String?               @db.Text
  color       String                @default("#6366f1")
  x           Int                   @default(40)
  y           Int                   @default(40)
  width       Int                   @default(420)
  height      Int                   @default(320)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  project     Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activities  FeatureGroupActivity[]
}

model FeatureGroupActivity {
  id             String       @id @default(cuid())
  featureGroupId String
  activityId     String
  featureGroup   FeatureGroup @relation(fields: [featureGroupId], references: [id], onDelete: Cascade)
  activity       Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([featureGroupId, activityId])
}
