# Copie este arquivo para .env e preencha os valores

# Postgres
POSTGRES_USER=roadmap
POSTGRES_PASSWORD=roadmap
POSTGRES_DB=roadmapstrix

# Para dev local (Docker): postgresql://roadmap:roadmap@localhost:5432/roadmapstrix
# Para produção: string de conexão do seu provedor (Supabase, Neon, Railway, etc.)
DATABASE_URL="postgresql://roadmap:roadmap@localhost:5432/roadmapstrix"

# NextAuth — gere com: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
